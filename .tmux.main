# Submenu: python
bind -T menus "y" display-menu -T " Python... " \
". ./.venv/bin/activate ............." "y" "send-keys '. .venv/bin/activate' enter" \
"" \
"Setup (u)v ........................." "u" setup_python_uv \
"Setup classic .venv ................" "V" setup_python_venv \
"Setup jupyterlab ..................." "J" "send-keys ' time cat <<\"EOF\" | bash' enter ; setup_python_uv ; send-keys 'uv venv ; . .venv/bin/activate ;' ; setup_jupyterlab ; send-keys 'EOF' enter '" \
"Setup (s)treamlit .................." "s" "send-keys ' time cat <<\"EOF\" | bash' enter ; setup_python_uv ; send-keys 'uv venv ; . .venv/bin/activate ; uv pip install streamlit[charts] ; streamlit hello ' ; send-keys enter 'EOF' enter '"

