"Download frankenphp ................" "f" setup_frankenphp \
"Download php composer .............." "c" setup_composer \
"Install php (apt) .................." "P" setup_php \
"" \
"Download adminer ..................." "a" get_adminer \
"Install phpcs ......................" "" setup_phpcs \
"Install phpstan ...................." "" setup_phpstan \
"" \
"php+node+mysql ....................." "1" "send-keys ' time cat <<\"EOF\" | bash' enter ; setup_basics_eatmydata ; setup_kkrc ; setup_php ; setup_node ; setup_mysql ; send-keys 'EOF' enter '. ~/.bashrc' enter" \
"php+node+psql ......................" "2" "send-keys ' time cat <<\"EOF\" | bash' enter ; setup_basics_eatmydata ; setup_kkrc ; setup_php ; setup_node ; setup_postgres ; send-keys 'EOF' enter '. ~/.bashrc' enter" \
"php+docker ........................." "3" "send-keys ' time cat <<\"EOF\" | bash' enter ; setup_basics_eatmydata ; setup_kkrc ; setup_php ; setup_node ; setup_docker ; send-keys 'EOF' enter '. ~/.bashrc' enter" \
