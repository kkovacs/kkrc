# CTRL-Q is much natural than CTRL-B, and doesn't clash with screen's CTRL-A.
# (CTRL-Q = XOFF anyway, which you most likely don't use in the 21st century)
set -g prefix c-q

# Design. Use only plain unicode, still look somewhat special. No powerline special font needed
#sepa=''	# Design #0
#sepa='▌'	# Design #1
#sepa='▌▌'	# Design #2
#sepa='▚'	# Design #3
sepa='▚▚'	# Design #4
#sepa='▏▎▍▌▋▊▉'	# Design #5
#sepa='▎▌▊'	# Design #6

# Status command on the right, between the clock and the screen size.
mystat="%Y-%m-%d %a"			# Date with DOW, OS independent
#mystat="#(ipconfig getifaddr en0 || echo No WiFi)"	# WiFi IP on OS X

# To make SHIFT+ENTER et al to work. Tested in iTerm2 and Ghostty.
# Thanks, https://blog.fsck.com/releases/2026/02/26/terminal-keyboard-protocol/
# Forward extended key sequences to applications
set -gs extended-keys on
# Use CSI u encoding format
set -gs -q extended-keys-format csi-u
# Tell tmux your outer terminal supports extended keys
# Adjust the glob to match your terminal's $TERM value
set -as terminal-features 'xterm*:extkeys'

# Theme originally from https://github.com/jimeh/tmux-themepack/blob/master/powerline/block/magenta.tmuxtheme
# and slightly modified (see below). You can find other color schemes there too!
#set -g @themecolour colour125 # magenta
#set -g @themecolour colour26 # blue
#set -g @themecolour colour39 # cyan
#set -g @themecolour colour245 # gray
#set -g @themecolour colour41 # green
#set -g @themecolour colour127 # purple
#set -g @themecolour colour130 # brown
#set -g @themecolour colour15 # white
set -g @themecolour colour202 # orange

set -g @gray1 colour235
set -g @gray2 colour239
set -g @gray3 colour243
set -g @gray4 colour245
set -g @gray5 colour250

# I switched colour90 => colour125
set -g status-style "bg=#{@gray1},fg=#{@gray5}"
set -g status-left-style "bg=#{@gray1},fg=#{@gray3},bold"
set -g status-right-style "bg=#{@gray1},fg=#{@gray3},bold"
set -g status-right-length "150"
set -g window-status-format " #I:#W#F "
set -g window-status-current-format " #I:#W#F "
set -g window-status-current-style "bg=#{@themecolour},fg=#{@gray1},bold"
set -g window-status-activity-style "bg=#{@gray2},fg=#{@gray5}"
set -g window-status-bell-style "bg=#{@gray2},fg=#{@gray5}"
set -g window-status-separator ""
set -g status-justify centre
set -g pane-border-style "bg=default,fg=colour240"
set -g pane-active-border-style "bg=default,fg=#{@themecolour}"
set -gF display-panes-colour "#{@gray4}"
set -gF display-panes-active-colour "#{@gray3}"
set -gF clock-mode-colour "#{@themecolour}"
set -g clock-mode-style "24"
set -g message-style "bg=#{@themecolour},fg=black"
set -g message-command-style "bg=#{@gray1},fg=black"
set -g mode-style "bg=#{@themecolour},fg=colour231"

# Modifications compared to the original theme
set -g status-left-length 100
set -g status-left "#[fg=#{@gray1},bg=#{@themecolour},bold] #{?client_prefix,Q,-}#{?pane_pipe,P,-} #{?alternate_on,A,-}#{?window_zoomed_flag,Z,-} #{?monitor-activity,a,-}#{?monitor-silence,s,-} #{?mouse,-,M}#{?synchronize-panes, [BCAST],}#{?session_many_attached, [MANY],} #[fg=#{@gray3},bg=#{@themecolour},nobold]$sepa#[fg=#{@gray1},bg=#{@gray4}] #{pane_pid} #[fg=#{@gray2},bg=#{@gray4}]$sepa#[fg=#{@gray5},bg=#{@gray2}] #S:#I.#P #[fg=#{@gray1},bg=#{@gray2},nobold]$sepa"
set -g status-right "#[fg=#{@gray2},bg=#{@gray1}]$sepa#[fg=#{@gray5},bg=#{@gray2}] #{pane_width}x#{pane_height} #[fg=#{@gray4},bg=#{@gray2}]$sepa#[fg=#{@gray1},bg=#{@gray4}] $mystat #[fg=#{@themecolour},bg=#{@gray4}]$sepa#[fg=#{@gray1},bg=#{@themecolour},bold] %H:%M %Z "

# Force the status line to ON
set -g status on

# Always use ~ as the dir for new panes, not wherever tmux was started from
#attach-session -t . -c ~

# Allow to send CTRL-Q
bind q send-prefix

# CTRL-Q CTRL-Q goes back to last window, like in screen
bind c-q last-window
#set -g base-index 1

# To make screen easier to use if accidentally hit CTRL-Q instead of CTRL-A or CTRL-W
bind c-a send-keys c-a
bind c-s send-keys c-s
bind a send-keys c-a
bind w send-keys c-w

# Toggle broadcasting input to all panes.
bind b set synchronize-panes

# Toggle tmux "mouse" functionality
bind m set mouse
bind M set mouse on

# Copy mode
bind Escape copy-mode
# Paste immediately
bind c-p paste-buffer
# Select what buffer to paste
bind p choose-buffer -Z
bind P choose-buffer

# Keys INSIDE copy-mode
bind -T copy-mode-vi Escape send -X cancel
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi V send -X select-line
bind -T copy-mode-vi C-v send -X rectangle-toggle
bind -T copy-mode-vi Enter send -X copy-selection-and-cancel
bind -T copy-mode-vi y send -X copy-selection-and-cancel
bind -T copy-mode-vi Y send -X append-selection-and-cancel
bind -T copy-mode-vi c-y send -X copy-pipe-and-cancel 'cat >>~/Desktop/tmux-copy.#S.#I.#P.#W.txt'

# Set word separators for word selection
set -g word-separators " `'\"{}()[],;<>"
# Write to system clipboard, but don't read it
set -s set-clipboard external

# Pane management
bind Enter select-pane -m
bind S join-pane
bind V join-pane -h
bind o break-pane
bind O break-pane -d

# Various comfort settings stolen from all over the net
set -g default-terminal tmux-256color
set -g status-keys vi
set -g renumber-windows on
set -g history-limit 100000
set -g mode-keys vi
set -g mouse on
# Automatically set window title
set -g automatic-rename on
set -g set-titles on
# No delay for escape key press
set -sg escape-time 0
# Leave messages on longer (or until keypress)
set -g display-time 1500
# Switch to a remaining session if one session is exited
set -g detach-on-destroy off

# Split vertically
bind v split-window -h
# Split horizontally
bind s split-window -v
# Window chooser
bind "\"" choose-window -Z
bind "\'" choose-session -Z
# New session
bind C command-prompt "new-session -s '%%'"
# Rename window
bind A command-prompt -I "#W" "rename-window '%%'"
# Move pane to window
#bind m choose-window -Z "move-pane -h -t '%%'"
# Move window to session and switch to there
#bind M choose-session -Z "move-window -t \"%1\"; switch-client -t \"%1\""
# Move window left and right
bind , swap-window -d -t -1
bind . swap-window -d -t +1

# Switch windows with C-Tab and C-S-Tab.
bind-key -n C-Tab next-window
bind-key -n C-S-Tab previous-window
bind-key -n C-BTab previous-window
# Instead, what works (plus, need to add this to iTerm):
set -s user-keys[0] "\e[1;5I"
set -s user-keys[1] "\e[1;6I"
bind-key -n User0 next-window
bind-key -n User1 previous-window

# Pane layouts
bind > next-layout
bind < previous-layout
# Spread out panes equally
bind = select-layout -E

# Move panes around
# XXX Same as default
#bind { swap-pane -U
#bind } swap-pane -D

# Pane resize options
bind J resize-pane -D 5
bind K resize-pane -U 5
bind H resize-pane -L 5
bind L resize-pane -R 5

# Vim style pane selection
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R
bind c-h select-pane -L
bind c-j select-pane -D
bind c-k select-pane -U
bind c-l select-pane -R
bind [ select-pane -t :.-
bind ] select-pane -t :.+
bind Tab select-pane -t :.+
bind i display-panes

# Use Alt-arrow keys without prefix key to switch panes
bind -n M-Left select-pane -L
bind -n M-Right select-pane -R
bind -n M-Up select-pane -U
bind -n M-Down select-pane -D

# To interate through windows with space and backspace
bind BSpace previous-window
bind Space next-window
bind n next-window
bind N previous-window
# Jump to window with bell
bind c-x next-window -a

# Do not auto-copy on mouse drag end
unbind -T copy-mode-vi MouseDragEnd1Pane
# Drag start in normal mode also starts selection of word
bind -n MouseDrag1Pane copy-mode -t= \; send-keys -X select-word

# Toggle monitoring activity and/or silence. Have the same keys as `screen`
bind "#" set -w monitor-activity
bind _ if -F '#{monitor-silence}' 'set -w monitor-silence 0' 'set -w monitor-silence 30'
# Global default
set -g monitor-activity off
# Pass them up the chain
set -g activity-action any
set -g bell-action any # Default any

# Clear pane
bind r send-keys -R \; clear-history \; refresh-client \; send-keys ^L

# Kill pane/window
bind x confirm-before -p "kill-pane #P? (y/n)" kill-pane

# Log pane output to file (toggle)
bind | pipe-pane -o 'cat >>~/Desktop/tmux-output.#S.#I.#P.#W.txt'

# Hardcopy pane visible
bind y command-prompt -1 -p "Hardcopy VISIBLE pane in (a)scii or (c)olor?" "if-shell -F '#{==:%%,a}' 'capture-pane -J -b hardcopy' 'capture-pane -e -b hardcopy' ; save-buffer -b hardcopy '$HOME/Desktop/tmux-visible.#S.#I.#P.#W.#{client_activity}.txt' ; delete-buffer -b hardcopy ; display Saved"
# Hardcopy pane history
bind Y command-prompt -1 -p "Hardcopy HISTORY of pane in (a)scii or (c)olor?" "if-shell -F '#{==:%%,a}' 'capture-pane -S - -J -b hardcopy' 'capture-pane -S - -e -J -b hardcopy' ; save-buffer -b hardcopy '$HOME/Desktop/tmux-history.#S.#I.#P.#W.#{client_activity}.txt' ; delete-buffer -b hardcopy ; display Saved"

# Reload tmux config
bind R 'source-file ~/.kkrc/.tmux.main ; display ".tmux.main reloaded!"'

# Inject bash config. Easiest key, used all the time
bind c-w pipe-pane -I 'cat ~/.kkrc/inject-bash.txt'

# Inject bash config as if BROADCAST to all panes of current window.
bind W load-buffer -b staticsendbuf ~/.kkrc/inject-bash.txt \; run-shell -b 'for a in $(tmux list-panes -F \#\D); do tmux paste-buffer -t "$a" -b staticsendbuf; done; tmux delete-buffer staticsendbuf; exit 0'
# Inject minimalist ash config. Second easiest key, used a lot
bind c-e pipe-pane -I 'cat ~/.kkrc/inject-ash.txt'

# For further use:
#bind "^" usable
#bind "\\" usable
#bind "@" usable
#bind "\$" usable
#bind "%" usable (default: split)
#bind "!" usable (default: break-pane)
#bind "&" usable (default: kill-pane, but we have "x" instead)
#bind "/" usable
#bind "-" usable (default: delete-buffer)
#bind "+" usable
#bind "*" usable
#bind "e" usable
#bind "g" usable
#bind "B" usable
#bind "F" usable
#bind "G" usable
#bind "I" usable
#bind "Q" usable
#bind "T" usable
#bind "T" usable
#bind "X" usable
#bind "Z" usable
#bind "c-c" usable
#bind "c-d" usable
#bind "c-f" usable
#bind "c-g" usable
#bind "c-n" usable
#bind "c-s" usable
#bind "c-t" usable
#bind "c-u" usable
#bind "c-v" usable
#bind "c-y" usable

# COMMAND ALIASES

# Add ssh public key to authorized_keys. Create dir if necessary, take care of permissions
set -s command-alias[101] setup_ssh_key="send-keys \" (umask 077; mkdir ~/.ssh 2>/dev/null; echo >>~/.ssh/authorized_keys '\" \; load-buffer -b staticsendbuf ~/.ssh/id_ed25519.pub \; paste-buffer -d -s '' -b staticsendbuf \; send-keys \"')\" enter"
# Install must-have packages on the remote system (Debian & derivatives)
BASIC="bash-completion curl dnsutils git gron htop jq less man psmisc rsync screen socat tig unattended-upgrades unzip vim-nox wget"
set -s command-alias[104] setup_basics_eatmydata="send-keys ' until sudo apt-get update; do sleep 1; done; [ -f /usr/bin/eatmydata ] || until sudo NEEDRESTART_MODE=a apt-get install -y eatmydata; do sleep 1; done; export EAT=eatmydata; until sudo NEEDRESTART_MODE=a eatmydata apt-get install -y less $BASIC; do sleep 1; done;' #enter"
# Install .kkrc
set -s command-alias[105] setup_kkrc="send-keys \" git clone --depth 1 https://github.com/kkovacs/kkrc/ ~/.kkrc; ~/.kkrc/install.sh; . ~/.bashrc\" enter"
# Poor server's Ansible. :)
set -s command-alias[106] setup_bashrc="load-buffer -b staticsendbuf ~/.kkrc/inject-func-lineinfile.txt \; paste-buffer -d -b staticsendbuf \; load-buffer -b staticsendbuf ~/.kkrc/inject-setup-bashrc.txt \; paste-buffer -d -b staticsendbuf"
# Install must-have packages on the remote system (RedHat & derivatives)
set -s command-alias[108] setup_centos="send-keys ' sudo yum install -y epel-release && sudo yum install -y bash-completion bind-utils curl git htop jq less psmisc rsync screen socat tar tig unzip util-linux vim wget' #enter"
# Install docker & docker-compose
# DO NOT USE THIS FOR PRODUCTION, we're cheating: to avoid having to long in-out to obtain the "docker" group, we pre-create the docker group with the current user's GID.
set -s command-alias[109] setup_docker="send-keys ' [[ \${GROUPS[0]} -gt 0 ]] && sudo groupadd -og \${GROUPS[0]} docker || true && until sudo NEEDRESTART_MODE=a \$EAT apt-get install -y docker.io docker-compose-v2; do sleep 1; done' enter"
# nodejs install
set -s command-alias[102] setup_node_snap="send-keys ' sudo snap install node --classic --channel=24' enter"
set -s command-alias[110] setup_node="send-keys ' mkdir -p ~/.local/node ; curl -L https://nodejs.org/dist/v24.13.1/node-v24.13.1-linux-\$(uname -m | sed \"s/x86_64/x64/; s/aarch64/arm64/\").tar.xz | tar Jxv --strip-components=1 --no-same-owner -C ~/.local/node && find ~/.local/node/bin/ -mindepth 1 -executable -exec ln -s \"{}\" ~/.local/bin/ \\;' enter"
set -s command-alias[103] setup_bun="send-keys ' mkdir -p ~/.local/bin ; curl -Lo /tmp/bun.zip https://github.com/oven-sh/bun/releases/latest/download/bun-linux-\$(uname -m | sed \"s/x86_64/x64/\").zip && unzip -j -o /tmp/bun.zip -d ~/.local/bin/ && ln -s bun ~/.local/bin/node' enter"
set -s command-alias[107] setup_pnpm="send-keys ' mkdir -p ~/.local/bin ; curl -Lo ~/.local/bin/pnpm https://github.com/pnpm/pnpm/releases/latest/download/pnpm-linux-\$(uname -m | sed \"s/x86_64/x64/; s/aarch64/arm64/\") && chmod 755 ~/.local/bin/pnpm' enter"
# Install PHP & composer
set -s command-alias[111] setup_php="send-keys ' mkdir -p ~/.local/bin ; NEEDRESTART_MODE=a \$EAT apt-get install -y $BASIC php-cli php-gd php-mbstring php-dom php-xml php-zip php-curl php-intl php-mysql php-pgsql php-sqlite3 php-xdebug && (curl -sS https://getcomposer.org/installer | NEEDRESTART_MODE=a php -- --install-dir=~/.local/bin --filename=composer)' enter"
# Minikube but running on local docker (for setting up playground/dev VMs)
set -s command-alias[112] setup_minikube="load-buffer -b staticsendbuf ~/.kkrc/inject-setup-minikube.txt \; paste-buffer -d -b staticsendbuf"
# Mysql, without any real password protection (default oracle password as cultural nod)
set -s command-alias[113] setup_mysql="send-keys ' sudo debconf-set-selections <<< \"mysql-server mysql-server/root_password password tiger\"; sudo debconf-set-selections <<< \"mysql-server mysql-server/root_password_again password tiger\"; sudo NEEDRESTART_MODE=a \$EAT apt-get install -y mysql-server' enter"
# Golang latest
set -s command-alias[114] setup_golang="send-keys ' mkdir -p ~/.local/bin ; type -p go || (cd /tmp; FNAME=\$(curl -s https://go.dev/dl/ | grep -om 1 \"go[[:digit:].]\\+linux-\$(uname -m | sed \"s/x86_64/amd64/; s/aarch64/arm64/\")\\.tar\\.gz\"|head -1); curl -LO \"https://go.dev/dl/\$FNAME\"; cd ~/.local/; tar zxf \"/tmp/\$FNAME\"; find ~/.local/go/bin/ -type f -executable -exec ln -s \"{}\" ~/.local/bin/ \\; );' enter"
# PostgreSQL
set -s command-alias[115] setup_postgres="send-keys ' sudo NEEDRESTART_MODE=a \$EAT apt-get install -y postgresql; export PGUSER=root PGPASSWORD=tiger PGHOST=127.0.0.1; printf \"\$PGPASSWORD\\n\$PGPASSWORD\" | sudo su - postgres -c \"createuser --superuser --pwprompt \\\"\$PGUSER\\\"\"' enter"
# Inject an .editorconfig
set -s command-alias[116] setup_editorconfig="send-keys ' cat >.editorconfig <<\"EOF\"' enter ; load-buffer -b staticsendbuf ~/.kkrc/.editorconfig ; paste-buffer -d -b staticsendbuf ; send-keys 'EOF' enter"
# Set up vim-go
set -s command-alias[118] setup_vim_go="send-keys ' git clone --depth 1 https://github.com/fatih/vim-go.git ~/.vim/pack/plugins/start/vim-go; vim -e -c GoInstallBinaries -c q' enter"
# Set up vim IDE
set -s command-alias[119] setup_vim_tagbar="send-keys ' git clone --depth 1 https://github.com/preservim/tagbar.git ~/.vim/pack/kkrc/start/tagbar; sudo NEEDRESTART_MODE=a apt install -y universal-ctags' enter"
# Gosec
set -s command-alias[120] setup_gosec="send-keys ' go install github.com/securego/gosec/v2/cmd/gosec@latest' enter '~/go/bin/gosec -r'"
# PHPCS
set -s command-alias[121] setup_phpcs="send-keys ' composer global require --dev squizlabs/php_codesniffer' enter '~/.config/composer/vendor/bin/phpcs'"
# Larastan
set -s command-alias[122] setup_phpstan="send-keys ' composer global require --dev phpstan/phpstan' enter '~/.config/composer/vendor/bin/phpstan analyse'"
# Shellcheck
set -s command-alias[123] setup_shellcheck="send-keys ' mkdir -p ~/.local/bin ; curl -L \"https://github.com/koalaman/shellcheck/releases/download/stable/shellcheck-stable.linux.\$(uname -m).tar.xz\" | tar -xJv --strip 1 -C ~/.local/bin/ shellcheck-stable/shellcheck' enter"
# XXX If apt actually installs, it "eats" the pre-typed command.
set -s command-alias[125] get_adminer="send-keys ' curl -Lo adminer.php https://www.adminer.org/latest-en.php' enter"
set -s command-alias[126] setup_duckdb="send-keys ' mkdir -p ~/.local/bin ; curl -Lo /tmp/duckdb.zip https://github.com/duckdb/duckdb/releases/latest/download/duckdb_cli-linux-\$(uname -m | sed s/x86_64/amd64/).zip && unzip -o /tmp/duckdb.zip -d ~/.local/bin/' enter"
set -s command-alias[127] setup_python_venv="send-keys ' sudo apt-get install -y python3-venv && python3 -m venv .venv; . .venv/bin/activate' enter"
set -s command-alias[128] setup_frankenphp="send-keys ' mkdir -p ~/.local/bin ; curl -Lo ~/.local/bin/frankenphp https://github.com/dunglas/frankenphp/releases/latest/download/frankenphp-linux-\$(uname -m) && chmod 755 ~/.local/bin/frankenphp' enter"
set -s command-alias[129] setup_composer="send-keys ' mkdir -p ~/.local/bin ; curl -Lo ~/.local/bin/composer https://github.com/composer/composer/releases/latest/download/composer.phar && chmod 755 ~/.local/bin/composer' enter"
set -s command-alias[130] setup_static_php_cli="send-keys ' mkdir -p ~/.local/bin ; curl -L https://dl.static-php.dev/static-php-cli/bulk/php-8.4.18-cli-linux-\$(uname -m).tar.gz | tar xz --no-same-owner -C ~/.local/bin/' enter"
set -s command-alias[131] get_pgweb="send-keys ' mkdir -p ~/.local/bin ; curl -Lo /tmp/pgweb.zip https://github.com/sosedoff/pgweb/releases/download/v0.17.0/pgweb_linux_\$(uname -m | sed \"s/x86_64/amd64/; s/aarch64/arm64/\").zip && unzip -o /tmp/pgweb.zip -d ~/.local/bin/' enter"
set -s command-alias[132] setup_jupyterlab="send-keys 'uv pip install jupyterlab jupysql itables psycopg2-binary jupyterlab-git plotly ipywidgets duckdb duckdb-engine magic-duckdb && while true; do jupyter lab --ip=0.0.0.0 --port=80; sleep 1; done' enter"
set -s command-alias[134] setup_python_uv="send-keys ' mkdir -p ~/.local/bin ; curl -L https://github.com/astral-sh/uv/releases/latest/download/uv-\$(uname -m)-unknown-linux-gnu.tar.gz | tar zxv -C ~/.local/bin/ --strip-components=1' enter"
set -s command-alias[124] setup_brew="send-keys ' NONINTERACTIVE=1 /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"' enter"
# IMPORTANT: Uses the INJECT_AI_... env vars. Use some throw-away key because it gets exposed easily, for example an OpenRouter key restricted to $5/month.
set -Fs command-alias[117] inject_ai_snippet="send-keys \" python3 -c \\\"import sys,json,urllib.request,os;u='#{INJECT_AI_URL}';h={'Authorization':'Bearer #{INJECT_AI_KEY}','Content-Type':'application/json'};d=json.dumps({'model':sys.argv[1],'messages':[{'role':'system','content':sys.argv[2]},{'role':'user','content':sys.stdin.read()}]}).encode();o=urllib.request.build_opener(urllib.request.ProxyHandler());print(json.loads(o.open(urllib.request.Request(u,data=d,headers=h)).read())['choices'][0]['message']['content'])\\\""

# PLEASE DONT USE: "j", "k", "q" IN ANY MENU!

# I'm hiding the submenus behind the "ctrl-q shift-6 ..." combo, because no sane person would ever use it :)
bind "^" switch-client -T menus

# Show inject menu. Trigger with: CTRL-Q CTRL-R
bind "c-r" display-menu -T " Inject... " \
"Submenu (c-r)emote-changing ......" "c-r" "send-keys -K c-q ^ c-r" \
"Inject vim config .................." "v" "pipe-pane -I 'cat ~/.kkrc/inject-vim.txt'" \
"Run tmux config ...................." "s" "pipe-pane -I 'cat ~/.kkrc/inject-tmux.txt'" \
"Run tmux PROD warning .............." "S" "pipe-pane -I 'cat ~/.kkrc/inject-tmux-red.txt'" \
"Reload .tmux.main .................." "R" "source-file ~/.kkrc/.tmux.main ; display '.tmux.conf reloaded!'" \
"Reload .tmux.local ................." "0" "source-file ~/.tmux.local ; display '.tmux.local reloaded!'" \
"Reload .tmux.init .................." "-" "source-file ~/.tmux.init" \
"Reload .tmux.conf (screen-like) ...." "" "source-file ~/.tmux.conf" \
"Inject e(x)-screen config .........." "x" "pipe-pane -I 'cat ~/.kkrc/inject-screen.txt'" \
"Inject e(X)-screen PROD warning ...." "X" "pipe-pane -I 'cat ~/.kkrc/inject-screen-red.txt'" \
"cat os-release ....................." "o" "send-keys \" cat /etc/os-release; systemd-detect-virt\" enter" \
"Inject fancy 'set -x' .............." "" "send-keys \"export PS4=\$'+\\\\tLine \\\$LINENO at \$(date -Iseconds): '\" enter" \
"unset (Q)UOTING_STYLE .............." "Q" "send-keys \" unset QUOTING_STYLE\" enter" \
"" \
"Submenu (c-d)atabases ............" "c-d" "send-keys -K c-q ^ d" \
"Submenu (c-e)nvironment .........." "c-e" "send-keys -K c-q ^ e" \
"Submenu (c-a)I ..................." "c-a" "send-keys -K c-q ^ a" \
"Submenu (c-g)o ..................." "c-g" "send-keys -K c-q ^ g" \
"Submenu (c-p)hp .................." "c-p" "send-keys -K c-q ^ p" \
"Submenu p(c-y)thon ..............." "c-y" "send-keys -K c-q ^ y" \
"Submenu (n)odejs ................." "c-n" "send-keys -K c-q ^ n" \
"Submenu (c-t)ools/platforms ......" "c-t" "send-keys -K c-q ^ t" \
"Submenu (c-v)im .................." "c-v" "send-keys -K c-q ^ v" \
"Submenu (c-z)modem-like .........." "c-z" "send-keys -K c-q ^ z" \
"Submenu (c-l)ocal ................" "c-l" "send-keys -K c-q ^ c-l"

# Commands that do CHANGE the remote system.
# The main purpose of these shortcuts is to quickly set up ephemeral dev-VMs.
# Thus we use eatmydata to speed things up (especially on btrfs and xfs) and don't care about safety.

# Submenu: kkrc
bind -T menus "c-r" display-menu -T " Modify... " \
"Setup kkrc ........................." "" setup_kkrc \
"apt basics + setup kkrc............." "r" "send-keys ' time cat <<\"EOF\" | bash' enter '[ ! -f /usr/bin/tig ] && {' ; setup_basics_eatmydata ; send-keys ' } ; [ ! -d ~/.kkrc ] && {' ; setup_kkrc ; send-keys '}' enter 'EOF' enter '. ~/.bashrc' enter" \
"yum basics ........................." "y" setup_centos \
"apk add basics ....................." "K" "send-keys ' apk add bash bash-completion curl git htop less psmisc rsync screen shadow socat sudo tig unzip vim wget zip && chsh --shell /bin/bash && exec bash' enter" \
"Agressive apt (u)pgrade ............" "u" "send-keys 'sudo \$EAT apt update && sudo \$EAT NEEDRESTART_MODE=a apt upgrade -y'" \
"" \
"Modify (A)uthorized_keys ..........." "A" setup_ssh_key \
"Drop .tmux.conf ...................." "s" "send-keys ' cat >~/.tmux.conf <<\"EOF\"' enter ; load-buffer -b staticsendbuf ~/.kkrc/.tmux.conf ; paste-buffer -d -b staticsendbuf ; send-keys 'EOF' enter" \
"Drop .screenrc ....................." "x" "send-keys ' cat >~/.screenrc <<\"EOF\"' enter ; load-buffer -b staticsendbuf ~/.kkrc/.screenrc ; paste-buffer -d -b staticsendbuf ; send-keys 'EOF' enter" \
"Drop .(e)ditorconfig ..............." "e" setup_editorconfig \
"" \
"Modify .(b)ashrc ..................." "b" setup_bashrc \
"Setup PROD (w)arn .................." "w" "send-keys ' printf \"\\033[00;31mPRODUCTION SERVER\\033[00m\" | sudo tee /etc/debian_chroot ; . ~/.bashrc' enter" \
"Remove PROD (W)arn ................." "W" "send-keys ' sudo rm /etc/debian_chroot; unset debian_chroot' enter" \
"" \
"sudo touch /(S)napshotme ..........." "S" "send-keys ' sudo touch /snapshotme; echo -n Commencing in ~\$(( 60 - \$( date +%S | sed 's/^0*//' ) )) secs; while [[ -f /snapshotme ]]; do echo -n .; sleep 1; done; echo' enter"

# Submenu: databases
bind -T menus "d" display-menu -T " DB... " \
"Download duckdb ...................." "d" setup_duckdb \
"Download pgweb ....................." "w" get_pgweb \
"" \
"apt install postgresql-client ......" "c" "send-keys 'sudo apt install -y postgresql-client' enter" \
"Install postgres ..................." "P" setup_postgres \
"Install mysql ......................" "M" setup_mysql \
"Install sqlite3 ...................." "L" "send-keys ' sudo apt-get install -y sqlite3' enter" \
"" \
"Inject (p)sql config ..............." "p" "pipe-pane -I 'cat ~/.kkrc/.psqlrc'" \
"" \
"CSV: startrek.csv (30 rows) ........" "1" "send-keys 'https://blobs.duckdb.org/data/Star_Trek-Season_1.csv'" \
"CSV: penguins.csv (344 rows) ......." "2" "send-keys 'https://blobs.duckdb.org/data/penguins.csv'" \
"stations.parquet (578 rows) ........" "3" "send-keys 'https://blobs.duckdb.org/stations.parquet'" \
"shakespeare.parquet (87K rows) ....." "4" "send-keys 'https://blobs.duckdb.org/data/shakespeare.parquet'" \
"tariffs.parquet (158K rows) ........" "5" "send-keys 'https://blobs.duckdb.org/tariffs.parquet'" \
"ontime.parquet (4M rows) ..........." "6" "send-keys 'https://blobs.duckdb.org/data/ontime.parquet'" \
"CSV: fin_fraud.csv (5M rows) ......." "8" "send-keys 'https://blobs.duckdb.org/data/financial_fraud_detection_dataset.csv'" \
"taxi.parquet (7M rows) ............." "7" "send-keys 'https://blobs.duckdb.org/data/taxi_2019_04.parquet'" \
"services_2023.parquet (21M rows) ..." "9" "send-keys 'https://blobs.duckdb.org/nl-railway/services-2023.parquet'"

