# Submenu: tools
bind -T menus "t" display-menu -T " Tools / platforms... " \
"mkdir foo & git init ..............." "g" "send-keys ' mkdir foo && cd foo && git init -b main && touch .gitignore && git add .gitignore && git -c user.email=\\\"$USER@$HOSTNAME\\\" -c user.name=\\\"$USER\\\" commit -m init && git status -sb' enter" \
"" \
"Docker run chrome --screenshot ....." "s" "send-keys 'sudo docker run -u `id -u $USER` -it --rm -v $(pwd):/usr/src/app --add-host host.docker.internal:host-gateway zenika/alpine-chrome --no-sandbox --window-size=1024,768 --screenshot --hide-scrollbars \"http://host.docker.internal:80/\"'" \
"Docker run chrome CDP .............." "c" "send-keys 'sudo docker run -u `id -u $USER` -it --rm -v $(pwd):/usr/src/app --add-host host.docker.internal:host-gateway -p 9222:9222 zenika/alpine-chrome --no-sandbox --remote-debugging-address=0.0.0.0 --remote-debugging-port=9222 --window-size=1024,768' enter" \
"Params for (c)hrome devtools ......." "D" "send-keys ' --remote-debugging-port=9222 --user-data-dir=/tmp/cdp/ --no-first-run --no-default-browser-check --disable-signin-promo --disable-sync --disable-infobars \\\"chrome://inspect/#remote-debugging\\\" ; rm -rf /tmp/cdp' enter" \
"" \
"Install (b)rew ....................." "b" setup_brew \
"Install (d)ocker ..................." "d" setup_docker \
"Install (m)inikube.................." "m" setup_minikube \
"Install (h)url ....................." "h" "send-keys ' mkdir -p ~/.local/bin ; curl -L https://github.com/Orange-OpenSource/hurl/releases/download/7.1.0/hurl-7.1.0-\$(uname -m)-unknown-linux-gnu.tar.gz | tar zxv -C ~/.local/bin/ --strip-components=2 --wildcards \"hurl-*/bin/hurl*\"' enter" \
"Install k(6) ......................." "6" "send-keys ' mkdir -p ~/.local/bin ; curl -L https://github.com/grafana/k6/releases/download/v1.7.1/k6-v1.7.1-linux-\$(uname -m | sed \"s/x86_64/amd64/; s/aarch64/arm64/\").tar.gz | tar zxv -C ~/.local/bin/ --strip-components=1 --wildcards \"*/k6\"' enter" \
"Install shell(C)heck ..............." "C" setup_shellcheck \
"Download (p)rettyping .............." "p" "send-keys ' mkdir -p ~/.local/bin ; curl -Lo ~/.local/bin/prettyping https://raw.githubusercontent.com/denilsonsa/prettyping/master/prettyping && chmod 755 ~/.local/bin/prettyping' enter 'prettyping 1.1.1.1' enter" \
"Install ~/(z)ig ...................." "z" "send-keys ' mkdir -p ~/.local/zig && curl -L https://ziglang.org/builds/zig-\$(uname -m)-linux-0.17.0-dev.9+046002d1a.tar.xz | tar Jxv --strip-components=1 -C ~/.local/zig ; ln -s ~/.local/zig/zig ~/.local/bin/zig' enter"

# Submenu: AI
opencode_config="\~/.config/opencode/opencode.json"
bind -T menus "a" display-menu -T " AI... " \
"Inject (a)i shell+python snippet...." "a" "inject_ai_snippet ; send-keys \"  \\\"#{INJECT_AI_MODEL}\\\" \\\"BLUF only:\\\"\"" \
"Inject (A)I bash function .........." "A" "send-keys \" function AI() {\" ; inject_ai_snippet \; send-keys \" \\\"\\\${2:-#{INJECT_AI_MODEL}}\\\" \\\"\\\$1\\\"; }; export -f AI\" enter" \
"Inject plan mode snippet ..........." "" "pipe-pane -I 'cat ~/.kkrc/inject-ai-planmode.md'" \
"Inject code review snippet ........." "" "pipe-pane -I 'cat ~/.kkrc/inject-ai-codereview.md'" \
"Inject go doc snippet .............." "" "pipe-pane -I 'cat ~/.kkrc/inject-ai-godoc.md'" \
"Inject duckdb snippet .............." "d" "pipe-pane -I 'cat ~/.kkrc/inject-ai-duckdb.md'" \
"Inject work-style snippet .........." "w" "pipe-pane -I 'cat ~/.kkrc/inject-ai-kk.md'" \
"Inject caveman snippet ............." "c" "pipe-pane -I 'cat ~/.kkrc/inject-ai-caveman.md'" \
"(g)it commit with AI message ......." "g" "send-keys 'git diff --cached | AI \"Please craft a git commit message from this. Just the text, no markdown code markers.\" | git commit -F -' enter" \
"" \
"Download (o)pencode................." "o" "send-keys ' mkdir -p ~/.local/bin ; curl -L https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-\$(uname -m | sed \"s/x86_64/x64/; s/aarch64/arm64/\")\.tar\.gz | tar zxv -C ~/.local/bin/ opencode' enter" \
"config reset ......................." "r" "send-keys ' mkdir -p ~/.config/opencode; echo \"{ \\\"\\\$schema\\\": \\\"https://opencode.ai/config.json\\\" }\" >#{opencode_config}' enter" \
"config MCP Chrome CDP..............." "9" "send-keys ' tmp=\$(mktemp); jq \".mcp[\\\"chrome-devtools\\\"] = {\\\"type\\\": \\\"local\\\", \\\"command\\\": [\\\"npx\\\", \\\"-y\\\", \\\"chrome-devtools-mcp@latest\\\", \\\"--browser-url=http://127.0.0.1:9222\\\"]}\" #{opencode_config} > \"\$tmp\" && mv \"\$tmp\" #{opencode_config}' enter" \
"config LLM on :8080 ................" "0" "send-keys ' tmp=\$(mktemp); jq \".provider[\\\"local\\\"] = {\\\"npm\\\": \\\"@ai-sdk/openai-compatible\\\", \\\"name\\\": \\\"local\\\", \\\"options\\\": {\\\"baseURL\\\": \\\"http://127.0.0.1:8080/v1\\\"}, \\\"models\\\": {\\\"any\\\": {\\\"name\\\": \\\"any\\\"}}}\" #{opencode_config} > \"\$tmp\" && mv \"\$tmp\" #{opencode_config}' enter" \
"Clean up opencode ................" "c-o" "send-keys ' rm -rf ~/{.config,.local/state,.local/share,.cache}/opencode ~/.bun ; rm -rf ~/.local/bin/opencode ' enter" \
"" \
"Download (p)i ......................" "p" "send-keys ' mkdir -p ~/.local/pi ; curl -L https://github.com/badlogic/pi-mono/releases/latest/download/pi-linux-\$(uname -m | sed \"s/x86_64/x64/; s/aarch64/arm64/\")\.tar\.gz | tar zxv -C ~/.local/; ln -s ~/.local/pi/pi ~/.local/bin/pi' enter" \
"Clean up pi ......................" "c-p" "send-keys ' rm -rf ~/pi ~/.pi' enter" \
"" \
"Download (C)laude code ............." "C" "send-keys ' curl -fsSL https://claude.ai/install.sh | bash' enter" \
"Download (k)ilo cli ................" "K" "send-keys ' mkdir -p ~/.local/bin ; curl -L https://github.com/Kilo-Org/kilocode/releases/latest/download/kilo-linux-\$(uname -m | sed \"s/x86_64/x64/; s/aarch64/arm64/\")\.tar\.gz | tar zxv -C ~/.local/bin/ kilo' enter"

# Submenu: environment
# Load age-encrypted environment variables in tmux session, so they can be injected.
# -h means hidden: variables don't get automatically added to new windows' environments and not shown by :show-environment
# NOTE: ENV loading needs to reload .tmux.main so "#{..}" variables in "set command-alias..."-es are expanded
bind -T menus "e" display-menu -T " inject from tmux session environment... " \
"Load (e)nv.age to tmux .................." "e" "display-popup -T \"Load env.age to tmux\" -EE bash -c \"age -i ~/.ssh/age.key -d ~/.ssh/env.age | awk '!/^\s*(\\\$|#)/ { sub(/=/, \\\" \\\"); print \\\"set-environment -h\\\", \$0 }' | tmux source-file -\" ; source-file ~/.kkrc/.tmux.main" \
"Inject \$GEMINI_API_KEY .................." "g" "send-keys ' stty -echo' enter ' export GEMINI_API_KEY=#{GEMINI_API_KEY} GOOGLE_GENERATIVE_AI_API_KEY=#{GEMINI_API_KEY}; stty echo' enter" \
"Inject \$GITHUB_TOKEN ...................." "G" "send-keys ' stty -echo' enter ' export GITHUB_TOKEN=#{GITHUB_TOKEN}; stty echo' enter" \
"Inject \$MISTRAL_API_KEY ................." "m" "send-keys ' stty -echo' enter ' export MISTRAL_API_KEY=#{MISTRAL_API_KEY}; stty echo' enter" \
"Inject \$NVIDIA_API_KEY .................." "n" "send-keys ' stty -echo' enter ' export NVIDIA_API_KEY=#{NVIDIA_API_KEY}; stty echo' enter" \
"Inject \$OPENCODE_API_KEY ................" "O" "send-keys ' stty -echo' enter ' export OPENCODE_API_KEY=#{OPENCODE_API_KEY}; stty echo' enter" \
"Inject \$OPENROUTER_API_KEY .............." "o" "send-keys ' stty -echo' enter ' export OPENROUTER_API_KEY=#{OPENROUTER_API_KEY}; stty echo' enter" \
"Inject \$OPENROUTER_API_KEY for Claude ..." "C" "send-keys ' stty -echo' enter ' export ANTHROPIC_BASE_URL=\"https://openrouter.ai/api\" ANTHROPIC_AUTH_TOKEN=\"#{OPENROUTER_API_KEY}\" ANTHROPIC_API_KEY=\"\"; stty echo' enter" \
"Inject \$XAI_API_KEY ....................." "x" "send-keys ' stty -echo' enter ' export XAI_API_KEY=#{XAI_API_KEY}; stty echo' enter" \
"" \
"Unset proxies ..........................." "-" 'send-keys " unset {http,https,all}_proxy {HTTP,HTTPS,ALL}_PROXY WSL_PAC_URL" enter' \
"Inject proxy socks5h:(1)080 (ssh -D 1080)" "1" 'send-keys " export all_proxy=socks5h://127.0.0.1:1080" enter' \
"Inject proxy http:888(8)................." "8" 'send-keys " export {http,https}_proxy=http://127.0.0.1:8888 {HTTP,HTTPS}_PROXY=http://127.0.0.1:8888" enter' \
"Inject proxy http:808(0)................." "0" 'send-keys " export {http,https}_proxy=http://127.0.0.1:8080 {HTTP,HTTPS}_PROXY=http://127.0.0.1:8080" enter' \
"" \
"Inject \$SSH_AUTH_SOCK ..................." "a" 'send-keys " export SSH_AUTH_SOCK=$(tmux show-environment SSH_AUTH_SOCK | cut -d= -f2)" enter'

# Submenu: vim
bind -T menus "v" display-menu -T " vim... " \
"Inject (v)im config ................" "v" "pipe-pane -I 'cat ~/.kkrc/inject-vim.txt'" \
"Inject modeline: preserve (t)abs ..." "t" "send-keys '# vim: set noexpandtab :'" \
"Inject modeline: tabs to (s)paces .." "s" "send-keys '# vim: set expandtab ts=4 sw=4 :'" \
"" \
"Install vim-tagbar ................." "t" setup_vim_tagbar \
"Install copilot.vim ................" "c" "send-keys ' sudo snap install node --classic --channel=22 && mkdir -p ~/.config/github-copilot && git clone --depth 1 https://github.com/github/copilot.vim.git ~/.vim/pack/kkrc/start/copilot && cat >~/.config/github-copilot/apps.json <<EOF' enter \; load-buffer -b staticsendbuf ~/.config/github-copilot/apps.json \; paste-buffer -d -b staticsendbuf \; send-keys 'EOF' enter"

# Submenu: zmodem-like (= binary-to-ascii and back)
bind -T menus "z" display-menu -T " Zmodem... " \
"Poor man's \"xxd\" with hexdump ...." "h" "send-keys \"hexdump -v -e '\\\"%08.8_ax:\\\"' -e '16/1 \\\" %02x\\\"' -e '\\\"  \\\" 16/1 \\\"%_p\\\" \\\"\\\\n\\\"' " \
"Poor man's \"xxd\" with od ........." "o" 'send-keys "od -v -A x -t x1z "' \
"" \
"Bytestream with hexdump .........." "b" "send-keys \"hexdump -v -e '32/1 \\\" %02x\\\" \\\"\\\\n\\\"' \"" \
"Bytestream reverse ..............." "r" "send-keys 'while read -r -d \" \" x; do [ -n \"\$x\" ] && printf \"\\x\${x}\"; done'"

# Local commands:
# Local menu - override from ~/.tmux.local
bind -T menus "c-l" display-menu -T " Local... " \
"Load ~/.tmux.local ..............." "0" "source-file ~/.tmux.local"
