bind -T menus "n" display-menu -T " NodeJS... " \
"Install nodejs (direct download) ..." "n" setup_node \
"Install bun ........................" "b" setup_bun \
"Install nodejs (snap) .............." "s" setup_node_snap \
"Install pnpm ......................." "p" setup_pnpm \
